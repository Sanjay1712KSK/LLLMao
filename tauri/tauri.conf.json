{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MyOwnRTXChat",
  "version": "0.1.0",
  "identifier": "com.myownrtxchat.desktop",
  "build": {
    "beforeDevCommand": "cd ../frontend && npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "cd ../frontend && npm run build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "MyOwnRTXChat",
        "width": 1280,
        "height": 820,
        "minWidth": 920,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src http://127.0.0.1:8000 http://localhost:8000 http://localhost:11434 http://127.0.0.1:11434; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "category": "DeveloperTool",
    "shortDescription": "Local Ollama AI workspace",
    "longDescription": "A lightweight Linux-native desktop workspace for already-installed local Ollama models.",
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0"]
      }
    }
  }
}
