{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LLLMao",
  "version": "0.1.0",
  "identifier": "com.lllmao.desktop",
  "build": {
    "beforeDevCommand": "cd ../frontend && npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "cd ../frontend && npm run build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "LLLMao",
        "width": 1280,
        "height": 820,
        "minWidth": 860,
        "minHeight": 640,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src http://127.0.0.1:8000 http://localhost:8000 http://localhost:11434 http://127.0.0.1:11434; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "category": "DeveloperTool",
    "shortDescription": "Local Ollama AI workspace",
    "longDescription": "LLLMao is a lightweight Linux-native desktop workspace for already-installed local Ollama models.",
    "homepage": "https://localhost/lllmao",
    "publisher": "LLLMao contributors",
    "copyright": "Copyright LLLMao contributors",
    "licenseFile": "../LICENSE",
    "icon": ["../deployment/assets/lllmao.svg"],
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      },
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1",
          "librsvg2-2",
          "python3",
          "python3-venv"
        ],
        "files": {
          "/usr/share/applications/com.lllmao.desktop.desktop": "../deployment/assets/com.lllmao.desktop.desktop"
        }
      }
    }
  }
}
